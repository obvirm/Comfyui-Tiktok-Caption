{
  "name": "Levi",
  "description": "Narrow left-anchored stack. Lines reveal one by one as they are narrated.",
  "categories": [
    "hook"
  ],
  "typography": {
    "fontFamily": "Anton",
    "fontWeight": 800,
    "fontSize": 6.0,
    "wordSpacing": 0.08,
    "lineSpacing": 0.09,
    "textCase": "uppercase",
    "textAlign": "left"
  },
  "styleControls": [
    {
      "id": "primary-color",
      "label": "Text",
      "type": "color",
      "default": "#ffffff",
      "group": "colors"
    },
    {
      "id": "shadow-color",
      "label": "Shadow",
      "type": "color",
      "default": "#000000",
      "advanced": true,
      "group": "colors"
    },
    {
      "id": "reveal-distance",
      "label": "Reveal distance",
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 1.0,
      "step": 0.01,
      "unit": "em",
      "group": "appearance"
    },
    {
      "id": "shadow-distance",
      "label": "Shadow distance",
      "type": "float",
      "default": 0.03,
      "min": 0,
      "max": 0.5,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    },
    {
      "id": "shadow-blur",
      "label": "Shadow blur",
      "type": "float",
      "default": 0.12,
      "min": 0,
      "max": 1.0,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    }
  ],
  "segmentSplitters": [
    {
      "type": "boundary"
    },
    {
      "type": "limit_by_scaled_chars",
      "maxChars": 80,
      "minChars": 40
    }
  ],
  "lineSplitter": {
    "type": "balanced-pixel-width",
    "minLines": 4,
    "maxLines": 8,
    "maxWidthRatio": 0.52
  },
  "alignment": {
    "verticalAlign": "center",
    "verticalOffset": 0.40,
    "horizontalAlign": "left",
    "horizontalOffset": 0.04
  },
  "unsupportedUserAgents": ["firefox"],
  "effects": [
    {
      "type": "gap_free",
      "enabled": true
    }
  ],
  "taggerRules": []
}
