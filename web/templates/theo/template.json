{
  "name": "Theo",
  "categories": [
    "clean"
  ],
  "typography": {
    "fontFamily": "Inter Variable",
    "fontWeight": 900,
    "fontSize": 3.0,
    "wordSpacing": 0.15
  },
  "styleControls": [
    {
      "id": "primary-color",
      "label": "Past word",
      "type": "color",
      "default": "#ffffff",
      "group": "colors"
    },
    {
      "id": "highlight-color",
      "label": "Active word",
      "type": "color",
      "default": "#ffd700",
      "group": "colors"
    },
    {
      "id": "upcoming-color",
      "label": "Upcoming word",
      "type": "color",
      "default": "#d8d8d8",
      "group": "colors"
    },
    {
      "id": "bg-color",
      "label": "Background",
      "type": "color",
      "default": "#000000",
      "group": "colors"
    },
    {
      "id": "shadow-color",
      "label": "Shadow",
      "type": "color",
      "default": "#000000",
      "advanced": true,
      "group": "colors"
    },
    {
      "id": "upcoming-opacity",
      "label": "Upcoming opacity",
      "type": "float",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.05,
      "group": "appearance",
      "legend": "How transparent words become before they are narrated."
    },
    {
      "id": "bg-opacity",
      "label": "Background opacity",
      "type": "float",
      "default": 0.55,
      "min": 0,
      "max": 1,
      "step": 0.05,
      "group": "appearance"
    },
    {
      "id": "bg-radius",
      "label": "Background radius",
      "type": "float",
      "default": 0.2,
      "min": 0,
      "max": 1.5,
      "step": 0.01,
      "unit": "em",
      "group": "appearance"
    },
    {
      "id": "bg-padding-x",
      "label": "Background padding X",
      "type": "float",
      "default": 0.55,
      "min": 0,
      "max": 3.0,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    },
    {
      "id": "bg-padding-y",
      "label": "Background padding Y",
      "type": "float",
      "default": 0.25,
      "min": 0,
      "max": 1.0,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    },
    {
      "id": "shadow-distance",
      "label": "Shadow distance",
      "type": "float",
      "default": 0.05,
      "min": 0,
      "max": 1.0,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    },
    {
      "id": "shadow-blur",
      "label": "Shadow blur",
      "type": "float",
      "default": 0.2,
      "min": 0,
      "max": 2.0,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    }
  ],
  "segmentSplitters": [
    {
      "type": "boundary",
      "mode": "sentence"
    },
    {
      "type": "limit_by_scaled_chars",
      "maxChars": 24,
      "minChars": 8
    }
  ],
  "lineSplitter": {
    "type": "balanced-pixel-width",
    "minLines": 1,
    "maxLines": 1,
    "maxWidthRatio": 0.85
  },
  "alignment": {
    "verticalAlign": "bottom",
    "verticalOffset": 0.78,
    "horizontalAlign": "center",
    "horizontalOffset": 0.5
  },
  "effects": [
    {
      "type": "gap_free",
      "enabled": true
    }
  ]
}
