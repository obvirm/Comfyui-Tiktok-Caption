{
  "name": "Freya",
  "categories": [
    "impact"
  ],
  "typography": {
    "fontFamily": "Anton",
    "fontWeight": 400,
    "fontSize": 5.5,
    "letterSpacing": 0.02,
    "wordSpacing": 0.12,
    "lineSpacing": -0.28,
    "textCase": "uppercase"
  },
  "rotation": {
    "angleDeg": -3
  },
  "rendering": {
    "padding": "1em"
  },
  "styleControls": [
    {
      "id": "text-color",
      "label": "Text",
      "type": "color",
      "default": "#ffffff",
      "group": "colors"
    },
    {
      "id": "highlight-color",
      "label": "Active word",
      "type": "color",
      "default": "#ffffff",
      "group": "colors"
    },
    {
      "id": "outline-color",
      "label": "Outline",
      "type": "color",
      "default": "#0a0a0a",
      "group": "colors"
    },
    {
      "id": "aberration-color-a",
      "label": "Aberration A",
      "type": "color",
      "default": "#ff0044",
      "group": "colors"
    },
    {
      "id": "aberration-color-b",
      "label": "Aberration B",
      "type": "color",
      "default": "#00f4ff",
      "group": "colors"
    },
    {
      "id": "outline-thickness",
      "label": "Outline thickness",
      "type": "float",
      "default": 0.1,
      "min": 0,
      "max": 0.3,
      "step": 0.01,
      "unit": "em",
      "group": "appearance"
    },
    {
      "id": "aberration-amount",
      "label": "Aberration distance",
      "type": "float",
      "default": 2.0,
      "min": 0,
      "max": 25,
      "step": 0.5,
      "group": "appearance"
    },
    {
      "id": "displacement-amount",
      "label": "Scan-line displacement",
      "type": "float",
      "default": 9,
      "min": 0,
      "max": 40,
      "step": 1,
      "group": "appearance"
    },
    {
      "id": "displacement-frequency",
      "label": "Scan-line density",
      "type": "float",
      "default": 0.75,
      "min": 0.05,
      "max": 1.5,
      "step": 0.05,
      "advanced": true,
      "group": "appearance"
    }
  ],
  "segmentSplitters": [
    {
      "type": "boundary",
      "mode": "clause"
    },
    {
      "type": "limit_by_scaled_chars",
      "maxChars": 22
    }
  ],
  "lineSplitter": {
    "type": "balanced-pixel-width",
    "maxLines": 2
  },
  "alignment": {
    "verticalAlign": "bottom",
    "verticalOffset": 0.84,
    "horizontalAlign": "center",
    "horizontalOffset": 0.5
  },
  "effects": [
    {
      "type": "emoji",
      "placement": "segment-above",
      "enabled": true
    },
    {
      "type": "remove_punctuation",
      "enabled": true
    }
  ]
}
