{
  "name": "Noor",
  "categories": [
    "impact"
  ],
  "typography": {
    "fontFamily": "Anton",
    "fontWeight": 900,
    "fontSize": 6.2,
    "letterSpacing": 0.02,
    "wordSpacing": 0.1,
    "textCase": "uppercase"
  },
  "styleControls": [
    {
      "id": "primary-color",
      "label": "Text",
      "type": "color",
      "default": "#ffd84d",
      "group": "colors"
    },
    {
      "id": "tag-color",
      "label": "Tagged words",
      "type": "color",
      "default": "#ffffff",
      "group": "colors"
    },
    {
      "id": "quote-color",
      "label": "Quote",
      "type": "color",
      "default": "#9ce874",
      "group": "colors"
    },
    {
      "id": "shadow-color",
      "label": "Shadow",
      "type": "color",
      "default": "#000000",
      "advanced": true,
      "group": "colors"
    },
    {
      "id": "outline-color",
      "label": "Outline",
      "type": "color",
      "default": "#000000",
      "advanced": true,
      "group": "colors"
    },
    {
      "id": "outline-thickness",
      "label": "Outline thickness",
      "type": "float",
      "default": 0.015,
      "min": 0,
      "max": 0.1,
      "step": 0.005,
      "unit": "em",
      "group": "appearance"
    },
    {
      "id": "shadow-distance",
      "label": "Shadow distance",
      "type": "float",
      "default": 0.08,
      "min": 0,
      "max": 0.5,
      "step": 0.01,
      "unit": "em",
      "group": "appearance"
    },
    {
      "id": "shadow-blur",
      "label": "Shadow blur",
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 2.0,
      "step": 0.05,
      "unit": "em",
      "group": "appearance"
    },
    {
      "id": "slide-distance",
      "label": "Slide distance",
      "type": "float",
      "default": 0.05,
      "min": 0,
      "max": 1.0,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance",
      "legend": "Distance the segment drops down on entry. 0 disables the slide."
    },
    {
      "id": "fade-start",
      "label": "Fade start",
      "type": "float",
      "default": 0.8,
      "min": 0,
      "max": 1,
      "step": 0.05,
      "advanced": true,
      "group": "appearance",
      "legend": "Starting opacity of the entry animation. 1 disables the fade."
    },
    {
      "id": "dynamic-font-size",
      "label": "Dynamic font size",
      "type": "toggle",
      "default": true,
      "valueOn": "12",
      "valueOff": "0",
      "group": "appearance",
      "legend": "Grows the font size on short captions so they fill the screen."
    }
  ],
  "segmentSplitters": [
    {
      "type": "boundary",
      "mode": "clause"
    },
    {
      "type": "limit_by_scaled_chars",
      "maxChars": 15,
      "minChars": 5
    }
  ],
  "lineSplitter": {
    "type": "balanced-pixel-width",
    "minLines": 1,
    "maxLines": 1,
    "maxWidthRatio": 0.8
  },
  "alignment": {
    "verticalAlign": "bottom",
    "verticalOffset": 0.82,
    "horizontalAlign": "center",
    "horizontalOffset": 0.5
  },
  "effects": [
    {
      "type": "gap_free",
      "enabled": true
    },
    {
      "type": "carry_quotes",
      "enabled": true
    },
    {
      "type": "smart_punctuation",
      "enabled": true
    }
  ],
  "unsupportedUserAgents": ["firefox"]
}
