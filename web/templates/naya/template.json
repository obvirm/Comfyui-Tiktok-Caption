{
  "name": "Naya",
  "categories": [
    "impact"
  ],
  "typography": {
    "fontFamily": "Anton",
    "fontWeight": 400,
    "fontSize": 4.69,
    "letterSpacing": 0.015,
    "wordSpacing": 0.14,
    "lineSpacing": 0.10,
    "textCase": "uppercase"
  },
  "rendering": {
    "padding": "1em"
  },
  "styleControls": [
    {
      "id": "primary-color",
      "label": "Text",
      "type": "color",
      "default": "#ffffff",
      "group": "colors"
    },
    {
      "id": "highlight-color",
      "label": "Highlight",
      "type": "color",
      "default": "#ffff00",
      "group": "colors"
    },
    {
      "id": "shadow-color",
      "label": "Shadow",
      "type": "color",
      "default": "#000000",
      "advanced": true,
      "group": "colors"
    },
    {
      "id": "outline-thickness",
      "label": "Outline thickness",
      "type": "float",
      "default": 0.14,
      "min": 0.04,
      "max": 0.16,
      "step": 0.01,
      "unit": "em",
      "group": "appearance"
    },
    {
      "id": "word-pop",
      "label": "Pop intensity",
      "type": "float",
      "default": 0.10,
      "min": 0,
      "max": 0.3,
      "step": 0.01,
      "group": "appearance"
    }
  ],
  "segmentSplitters": [
    {
      "type": "boundary"
    },
    {
      "type": "limit_by_scaled_chars",
      "maxChars": 35,
      "minChars": 8
    }
  ],
  "lineSplitter": {
    "type": "balanced-pixel-width",
    "maxLines": 2
  },
  "alignment": {
    "verticalAlign": "top",
    "verticalOffset": 0.75
  },
  "effects": [
    {
      "type": "emoji",
      "enabled": true,
      "placement": "segment-above",
      "gap": 1.4
    }
  ]
}
