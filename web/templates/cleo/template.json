{
  "name": "Cleo",
  "categories": [
    "clean",
    "multi-speakers"
  ],
  "variants": [
    { "label": "White", "overrides": { "primary-color": "#ffffff", "quote-color": "#e6d647" } },
    { "label": "Amber", "overrides": { "primary-color": "#ffd866", "quote-color": "#7be6ff" } },
    { "label": "Cyan", "overrides": { "primary-color": "#7be6ff", "quote-color": "#ffd866" } },
    { "label": "Green", "overrides": { "primary-color": "#86ff86", "quote-color": "#ff86c5" } },
    { "label": "Pink", "overrides": { "primary-color": "#ff86c5", "quote-color": "#86ff86" } }
  ],
  "typography": {
    "fontFamily": "Lora Variable",
    "fontWeight": 500,
    "fontSize": 4.3,
    "letterSpacing": 0,
    "wordSpacing": 0.13,
    "textAlign": "center"
  },
  "styleControls": [
    {
      "id": "primary-color",
      "label": "Text",
      "type": "color",
      "default": "#ffffff",
      "group": "colors"
    },
    {
      "id": "quote-color",
      "label": "Quote",
      "type": "color",
      "default": "#e6d647",
      "group": "colors"
    },
    {
      "id": "shadow-color",
      "label": "Shadow",
      "type": "color",
      "default": "#000000",
      "advanced": true,
      "group": "colors"
    },
    {
      "id": "outline-color",
      "label": "Outline",
      "type": "color",
      "default": "#000000",
      "advanced": true,
      "group": "colors"
    },
    {
      "id": "outline-thickness",
      "label": "Outline thickness",
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 0.3,
      "step": 0.01,
      "unit": "em",
      "group": "appearance"
    },
    {
      "id": "shadow-distance",
      "label": "Shadow distance",
      "type": "float",
      "default": 0.06,
      "min": 0,
      "max": 1.0,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    },
    {
      "id": "shadow-blur",
      "label": "Shadow blur",
      "type": "float",
      "default": 1.2,
      "min": 0,
      "max": 3.0,
      "step": 0.05,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    },
    {
      "id": "slide-distance",
      "label": "Slide distance",
      "type": "float",
      "default": 0.06,
      "min": 0,
      "max": 0.80,
      "step": 0.01,
      "unit": "em",
      "group": "appearance",
      "legend": "Distance the segment slides down on entry. 0 disables the slide."
    },
    {
      "id": "tag-weight",
      "label": "Emphasis weight",
      "type": "integer",
      "default": 900,
      "min": 100,
      "max": 900,
      "step": 100,
      "group": "appearance",
      "legend": "Weight applied to emphasis-tagged words."
    },
    {
      "id": "tag-italic",
      "label": "Italic tags",
      "type": "toggle",
      "default": true,
      "valueOn": "italic",
      "valueOff": "normal",
      "group": "appearance",
      "legend": "Italicizes accent and entity tagged words."
    },
    {
      "id": "dynamic-font-size",
      "label": "Dynamic font size",
      "type": "toggle",
      "default": true,
      "valueOn": "12",
      "valueOff": "0",
      "group": "appearance",
      "legend": "Grows the font size on short captions so they fill the screen."
    }
  ],
  "segmentSplitters": [
    {
      "type": "boundary",
      "mode": "clause"
    },
    {
      "type": "limit_by_scaled_chars",
      "maxChars": 18,
      "minChars": 7
    }
  ],
  "lineSplitter": {
    "type": "balanced-pixel-width",
    "minLines": 1,
    "maxLines": 1,
    "maxWidthRatio": 0.8
  },
  "alignment": {
    "verticalAlign": "bottom",
    "verticalOffset": 0.65,
    "horizontalAlign": "center",
    "horizontalOffset": 0.5
  },
  "effects": [
    {
      "type": "gap_free",
      "enabled": true
    },
    {
      "type": "carry_quotes",
      "enabled": true
    },
    {
      "type": "smart_punctuation",
      "enabled": true
    },
    {
      "type": "smart_lowercase",
      "enabled": true
    }
  ]
}
